# Copy to `.env` and adjust values for local development.
# Only variables prefixed with `VITE_` are exposed to the client bundle.

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000/api

# Display name used in the UI (optional)
VITE_APP_NAME=Coldop

# Public site origin used for canonical URLs / OG (no trailing slash)
VITE_SITE_URL=https://coldop.in

# TanStack Router / Query / Form devtools panel (true | false)
# Keep false (or unset) for production builds.
VITE_ENABLE_DEVTOOLS=true

# --- Analytics (optional; loaded only on public `/` when set) ---
# VITE_GTM_ID=GTM-XXXXXXX
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXX
# VITE_CLARITY_ID=
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
